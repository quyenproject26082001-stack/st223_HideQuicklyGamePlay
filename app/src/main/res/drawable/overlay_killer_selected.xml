<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- outer: green border, radius = innerRadius + strokeWidth = 5 + 5 = 10dp -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B4D334"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>

    <!-- inner: gray fill, inset 5dp, radius 5dp -->
    <item
        android:bottom="5dp"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#B35B5B5B"/>
            <corners android:radius="5dp"/>
        </shape>
    </item>

</layer-list>
