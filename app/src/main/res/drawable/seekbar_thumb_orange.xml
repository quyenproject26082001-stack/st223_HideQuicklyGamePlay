<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Vòng tròn ngoài - Viền Cam -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
            <size
                android:width="16dp"
                android:height="16dp"/>
        </shape>
    </item>

    <!-- Vòng tròn trong - Màu trắng -->
    <item
        android:top="1.5dp"
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#513323"/>
        </shape>
    </item>

</layer-list>