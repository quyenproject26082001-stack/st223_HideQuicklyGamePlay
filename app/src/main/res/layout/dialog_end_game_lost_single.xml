<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialog_end_game_single"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialogBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="27dp"
        android:background="@drawable/bg_dialog_endgame_single"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="310:237"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/ic_bg_text_dialog"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="50dp"
            android:background="@drawable/ic_bg_text_dialog"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                android:id="@+id/tvNumberLost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/tradewinds_regular"
                android:shadowColor="#80000000"
                android:shadowDy="6"
                android:shadowRadius="0.1"
                android:textColor="@color/white"
                android:textSize="24dp"
                tools:text="10" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/icDead"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/ic_dead"
            app:layout_constraintBottom_toBottomOf="@id/ic_bg_text_dialog"
            app:layout_constraintEnd_toEndOf="@id/ic_bg_text_dialog"
            app:layout_constraintStart_toStartOf="@id/ic_bg_text_dialog"
            app:layout_constraintTop_toTopOf="@id/ic_bg_text_dialog"></FrameLayout>


        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvBody"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fontFamily="@font/tradewinds_regular"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowDy="6"
            android:shadowRadius="0.1"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp"
            app:layout_constraintBottom_toTopOf="@id/btnHome"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/icDead"
            tools:text="@string/you_picked_the_wrong_number" />


        <FrameLayout
            android:id="@+id/btnHome"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="45dp"
            android:background="@drawable/ic_home"
            app:layout_constraintTop_toTopOf="@id/btnPlayAgain"
            app:layout_constraintBottom_toBottomOf="@id/btnPlayAgain"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/btnPlayAgain"
            android:layout_width="156dp"
            android:layout_height="50dp"
            android:layout_marginEnd="45dp"
            android:layout_marginBottom="45dp"
            android:background="@drawable/frame_btn"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/tvPlayAgain"
                android:textSize="16sp"
                android:fontFamily="@font/tradewinds_regular"
                android:shadowColor="#80000000"
                android:shadowDy="6"
                android:text="@string/play_again"
                android:shadowRadius="0.1"
                android:textColor="@color/white"
                android:layout_gravity="center"
                android:gravity="center"
                />
        </FrameLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_marginBottom="-20dp"
        android:background="@drawable/bg_dialog_end_game_title_single"
        app:layout_constraintBottom_toTopOf="@id/dialogBody"
        app:layout_constraintDimensionRatio="160:40"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"></androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>