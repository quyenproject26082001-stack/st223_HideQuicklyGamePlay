<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_bg_app">

    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!-- Player turn banner -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPlayerTurn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar">

        <ImageView
            android:id="@+id/ivCurrentPlayerAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvCurrentPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/tradewinds_regular"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/ivCurrentPlayerAvatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp"
            android:text="Player 1's turn" />

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvTurnInstruction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/tradewinds_regular"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/ivCurrentPlayerAvatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentPlayerName"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp"
            android:shadowColor="#80000000"
            android:shadowDy="6"
            android:text="@string/choose_your_spot" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Map view -->
    <com.wanted.poster.hihi.activity_app.game.MapNumberView
        android:id="@+id/mapNumberView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:layout_marginBottom="70dp"
        app:layout_constraintTop_toBottomOf="@id/layoutPlayerTurn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
        android:id="@+id/btnConfirm"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="@string/confirm"
        android:shadowDy="6"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:textColor="@color/white"
        app:outerStrokeColor="@color/black"
        app:outerStrokeWidth="2dp"
        android:background="@drawable/img_home_0"
        android:fontFamily="@font/tradewinds_regular"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvAllReady"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:text="All players ready! \nStarting game..."
        android:fontFamily="@font/tradewinds_regular"
        android:shadowDy="6"
        android:shadowColor="#80FFFFFF"
        android:textColor="@color/white"
        app:outerStrokeColor="@color/black"
        app:outerStrokeWidth="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        android:visibility="gone"
        android:textSize="16sp"/>







</androidx.constraintlayout.widget.ConstraintLayout>
