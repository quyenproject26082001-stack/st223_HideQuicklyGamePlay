<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_bg_app">

    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!-- Player turn banner -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPlayerTurn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_parchment"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar">

        <ImageView
            android:id="@+id/ivCurrentPlayerAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvCurrentPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/tradewinds_regular"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/ivCurrentPlayerAvatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp"
            android:text="Player 1" />

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvTurnInstruction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/tradewinds_regular"
            android:textColor="#DDDDDD"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/ivCurrentPlayerAvatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCurrentPlayerName"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="1dp"
            android:text="@string/choose_your_spot" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Map view -->
    <com.wanted.poster.hihi.activity_app.game.MapNumberView
        android:id="@+id/mapNumberView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        app:layout_constraintTop_toBottomOf="@id/layoutPlayerTurn"
        app:layout_constraintBottom_toTopOf="@id/btnConfirm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Confirm button -->
    <FrameLayout
        android:id="@+id/btnConfirm"
        android:layout_width="200dp"
        android:layout_height="64dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/img_home_0"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/tradewinds_regular"
            android:text="@string/confirm_spot"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:shadowColor="#80000000"
            android:shadowDy="6"
            android:shadowRadius="0.01"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
