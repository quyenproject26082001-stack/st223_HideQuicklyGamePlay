<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_app.permission.PermissionActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_bg_language"/>

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>



    <!-- txtPermission -->
    <LinearLayout
        android:id="@+id/txtPermission"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="0dp"
        android:layout_marginTop="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgPermission">

        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/txtPer"
            android:fontFamily="@font/tradewinds_regular"
            android:layout_width="wrap_content"
            android:layout_marginHorizontal="50dp"
            app:outerStrokeWidth="2dp"
            app:outerStrokeColor="@color/black"
            android:shadowDy="7"
            android:shadowColor="#80000000"
            android:textColor="@color/white"
            android:shadowRadius="6"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- imgPermission -->
    <ImageView
        android:id="@+id/imgPermission"
        android:layout_width="300dp"
        android:layout_height="261dp"
        android:layout_marginTop="8dp"
        android:adjustViewBounds="true"
        android:src="@drawable/img_permission"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutActionBar" />

    <!-- scvButton -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="7dp"
        android:layout_marginBottom="4dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/txtPermission">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:orientation="vertical">

            <!-- btnStorage-->
            <RelativeLayout
                android:id="@+id/btnStorage"
                android:background="@drawable/bg_permission"
                android:layout_width="match_parent"
                android:layout_height="68dp">

                <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="36dp"
                    app:outerStrokeWidth="2dp"
                    app:outerStrokeColor="@color/black"
                    android:shadowDy="7"
                    android:shadowColor="#80000000"
                    android:shadowRadius="6"
                    android:fontFamily="@font/tradewinds_regular"
                    android:gravity="start"
                    android:text="@string/storage"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/swPermission"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginVertical="10dp"
                    android:layout_marginEnd="36dp"
                    android:src="@drawable/ic_sw_off" />
            </RelativeLayout>

            <!-- btnNotification-->
            <RelativeLayout
                android:id="@+id/btnNotification"
                android:layout_width="match_parent"
                android:background="@drawable/bg_permission"
                android:layout_height="68dp"
                >

                <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="36dp"
                    android:fontFamily="@font/tradewinds_regular"
                    android:gravity="start"
                    app:outerStrokeWidth="2dp"
                    app:outerStrokeColor="@color/black"
                    android:shadowDy="7"
                    android:shadowColor="#80000000"
                    android:shadowRadius="6"
                    android:text="@string/notification"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/swNotification"
                    android:layout_width="56dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginVertical="10dp"
                    android:layout_marginEnd="36dp"
                    android:src="@drawable/ic_sw_off" />
            </RelativeLayout>

        </LinearLayout>

    </ScrollView>

    <!--quyen-->
    <!-- nativePer -->
<!--    <FrameLayout-->
<!--        android:id="@+id/nativePer"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:layout_marginTop="7dp"-->
<!--        app:layout_constraintEnd_toEndOf="parent"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintBottom_toBottomOf="parent"-->
<!--        >-->

<!--        <include layout="@layout/ads_shimmer_big" />-->
<!--    </FrameLayout>-->
    <!--quyen-->


    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="@id/tvContinue"
        app:layout_constraintEnd_toEndOf="@id/tvContinue"
        app:layout_constraintTop_toTopOf="@id/tvContinue"
        app:layout_constraintBottom_toBottomOf="@id/tvContinue"
        android:id="@+id/tvContinueBG"
        android:padding="0dp"
        android:layout_marginStart="-20dp"
        android:layout_marginEnd="-20dp"
        android:layout_marginTop="-20dp"
        android:layout_marginBottom="-20dp"
        android:src="@drawable/blur_img"
        />
    <!-- tvContinue -->
    <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvContinue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:fontFamily="@font/tradewinds_regular"
        android:gravity="center"
        android:text="@string/continue_per"
        android:textSize="20sp"
        app:outerStrokeWidth="2dp"
        app:outerStrokeColor="@color/black"
        android:shadowDy="7"
        android:shadowColor="#80000000"
        android:shadowRadius="6"
        android:textColor="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="90dp"
        android:layout_marginTop="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
      />



</androidx.constraintlayout.widget.ConstraintLayout>