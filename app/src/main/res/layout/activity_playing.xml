<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- Map full screen + killer + numbers -->
    <com.wanted.poster.maker.activity_app.game.MapNumberView
        android:id="@+id/mapNumberView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="@drawable/bg_circle_black_50"
        android:src="@drawable/ic_back"
        android:contentDescription="Back" />

    <!-- Pause button -->
    <Button
        android:id="@+id/btnPause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:text="⏸"
        android:textSize="18sp"
        android:backgroundTint="#AA000000"
        android:textColor="#FFFFFF"
        android:padding="0dp" />

    <!-- Status text (shown during animation) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="#CC000000"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:textColor="#FFCC00"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- REVEAL button -->
    <Button
        android:id="@+id/btnReveal"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="TAP TO REVEAL KILLER"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B71C1C" />

</FrameLayout>
