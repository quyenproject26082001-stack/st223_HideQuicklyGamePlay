<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/img_bg_app">





    <!-- Map full screen + killer + numbers -->
    <com.wanted.poster.hihi.activity_app.game.MapNumberView
        android:id="@+id/mapNumberView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"

        />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="38dp"
        android:elevation="3dp"

        android:layout_height="38dp"
        android:background="@drawable/ic_back"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="54dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        />

    <!-- Pause button -->
    <ImageView
        android:id="@+id/btnPause"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/ic_resume"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="54dp"
        android:elevation="3dp"
        android:layout_marginEnd="16dp"
        android:padding="0dp" />

    <View
        android:id="@+id/viewOverlayDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone" />

    <com.wanted.poster.hihi.activity_app.game.CountdownRadarView
        android:id="@+id/countdownRadarView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Overlay text for pause/countdown -->
    <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvOverLay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="PAUSED"
        android:shadowColor="#80000000"
        android:shadowRadius="0.1"
        android:shadowDy="6"
        app:outerStrokeWidth="2dp"
        app:outerStrokeColor="@color/black"
        android:textColor="@color/white"
        android:fontFamily="@font/tradewinds_regular"
        android:textSize="42sp"
        android:visibility="visible" />


</androidx.constraintlayout.widget.ConstraintLayout>
