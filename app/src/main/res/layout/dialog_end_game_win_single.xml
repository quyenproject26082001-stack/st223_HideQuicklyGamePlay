<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialog_end_game_single"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <FrameLayout
        android:layout_width="419dp"
        android:layout_height="279dp"
        android:background="@drawable/ic_bloom"
        app:layout_constraintBottom_toTopOf="@id/dialogBody"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-150dp"
        />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dialogBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="27dp"
        android:background="@drawable/bg_dialog_endgame_single_win"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="310:237"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/ic_bg_text_dialog"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/ic_bg_text_dialog_win"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                android:id="@+id/tvNumberWin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/tradewinds_regular"
                android:shadowColor="#80000000"
                android:shadowDy="6"
                android:layout_marginTop="5dp"
                android:shadowRadius="0.1"
                android:textColor="@color/white"
                android:textSize="24dp"
                tools:text="10" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="198dp"
            android:layout_height="24dp"
            android:background="@drawable/ic_bloom_1"
            app:layout_constraintTop_toTopOf="@id/ic_bg_text_dialog"
            app:layout_constraintBottom_toBottomOf="@id/ic_bg_text_dialog"
            app:layout_constraintStart_toStartOf="@id/ic_bg_text_dialog"
            app:layout_constraintEnd_toEndOf="@id/ic_bg_text_dialog"/>


        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:id="@+id/tvBody"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fontFamily="@font/tradewinds_regular"
            android:gravity="center"
            android:shadowColor="#33000000"
            android:shadowDy="6"
            android:shadowRadius="0.1"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:outerStrokeColor="@color/black"
            android:layout_marginHorizontal="20dp"
            app:outerStrokeWidth="2dp"
            app:layout_constraintBottom_toTopOf="@id/btnHome"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ic_bg_text_dialog"
            tools:text="@string/you_survived_this_round_successfully" />


        <FrameLayout
            android:id="@+id/btnHome"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="45dp"
            android:background="@drawable/ic_home"
            app:layout_constraintTop_toTopOf="@id/btnPlayAgain"
            app:layout_constraintBottom_toBottomOf="@id/btnPlayAgain"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/btnPlayAgain"
            android:layout_width="156dp"
            android:layout_height="50dp"
            android:layout_marginEnd="45dp"
            android:layout_marginBottom="45dp"
            android:background="@drawable/frame_btn"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/tvPlayAgain"
                android:textSize="16sp"
                android:fontFamily="@font/tradewinds_regular"
                android:shadowColor="#80000000"
                android:shadowDy="6"
                android:text="@string/play_again"
                android:shadowRadius="0.1"
                android:textColor="@color/white"
                android:layout_gravity="center"
                android:gravity="center"
                />
        </FrameLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_marginBottom="-20dp"
        android:background="@drawable/bg_dialog_end_game_title_single_win"
        app:layout_constraintBottom_toTopOf="@id/dialogBody"
        app:layout_constraintDimensionRatio="160:40"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/you_win"
            android:fontFamily="@font/tradewinds_regular"
            android:textColor="#01B401"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:layout_marginStart="10dp"
            app:outerStrokeColor="@color/white"
            android:shadowColor="#80000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ic_cup"
            app:outerStrokeWidth="2dp"
            android:textSize="20sp"
            android:shadowDy="6"
            android:shadowRadius="0.1"
            android:gravity="center"
            android:id="@+id/tvTitle"/>
        
        <ImageView
            android:layout_width="20dp"
            android:layout_height="17dp"
            android:src="@drawable/ic_cup"
            android:scaleType="fitXY"
            android:id="@+id/ic_cup"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvTitle"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>