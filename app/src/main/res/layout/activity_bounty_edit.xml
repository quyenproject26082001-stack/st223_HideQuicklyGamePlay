<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".activity_app.bountyedit.BountyEditActivity">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_bg_language" />

    <!-- Action Bar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!-- ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:layout_constraintVertical_bias="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Poster Preview Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvPosterPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <FrameLayout
                    android:id="@+id/containerPoster"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:clipChildren="false"
                    android:clipToPadding="false" />

            </androidx.cardview.widget.CardView>

            <!-- Bounty Editing Card -->

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/cardBountySection"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:layout_gravity="bottom"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_edit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="true"
            android:overScrollMode="never"
            android:paddingTop="50dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"

                >


                <!-- Bounty Content -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutBountyContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="20dp">

                    <!-- Input Label -->
                    <TextView
                        android:id="@+id/tvBountyInputLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/input"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/edtBounty"
                        android:layout_width="0dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_16_stroke_white"
                        android:fontFamily="@font/roboto_regular"
                        android:hint="@string/enter_bounty"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:maxLength="14"
                        android:maxLines="1"
                        android:paddingHorizontal="12dp"
                        android:singleLine="true"
                        android:layout_marginEnd="71dp"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:layout_marginStart="20dp"
                        app:layout_constraintBottom_toBottomOf="@id/tvBountyInputLabel"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvBountyInputLabel"
                        app:layout_constraintTop_toTopOf="@id/tvBountyInputLabel" />

                    <!-- Fonts Label -->
                    <TextView
                        android:id="@+id/tvFontBountyLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="Fonts"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/edtBounty" />

                    <!-- Font Selector -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rcvFont"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:orientation="horizontal"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvFontBountyLabel"
                        tools:listitem="@layout/item_font_selector" />

                    <!-- Size Label -->
                    <TextView
                        android:id="@+id/tvBountySizeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/size"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rcvFont" />

                    <SeekBar
                        android:id="@+id/seekBarBountySize"
                        style="@style/CustomSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="50"
                        android:splitTrack="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBountySizeLabel" />

                    <!-- Weight Label -->
                    <TextView
                        android:id="@+id/tvBountyWeightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/weight"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/seekBarBountySize" />

                    <SeekBar
                        android:id="@+id/seekBarBountyWeight"
                        style="@style/CustomSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="50"
                        android:splitTrack="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBountyWeightLabel"

                        />

                    <!-- Spacing Label -->
                    <TextView
                        android:id="@+id/tvBountySpacingLabel"
                        style="@style/single_marquee"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="10dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/spacing"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@id/guideline1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/seekBarBountyWeight" />

                    <SeekBar
                        android:id="@+id/seekBarBountySpacing"
                        style="@style/CustomSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"
                        android:splitTrack="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBountySpacingLabel" />

                    <!-- Position X Label -->
                    <TextView
                        android:id="@+id/tvBountyPositionXLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/position_x"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/seekBarBountySpacing" />

                    <SeekBar
                        android:id="@+id/seekBarBountyPositionX"
                        style="@style/CustomSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="50"
                        android:splitTrack="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBountyPositionXLabel" />

                    <!-- Position Y Label -->
                    <TextView
                        android:id="@+id/tvBountyPositionYLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/tradewinds_regular"
                        android:text="@string/position_y"
                        android:textColor="@color/app"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/seekBarBountyPositionX" />

                    <SeekBar
                        android:id="@+id/seekBarBountyPositionY"
                        style="@style/CustomSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="50"
                        android:splitTrack="false"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvBountyPositionYLabel" />

                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guideline1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.29" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
