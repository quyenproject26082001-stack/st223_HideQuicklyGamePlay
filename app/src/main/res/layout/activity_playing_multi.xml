<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_bg_app">

    <com.wanted.poster.hihi.activity_app.game.MapNumberView
        android:id="@+id/mapNumberView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/ic_back"
        android:elevation="3dp"
        android:scaleType="fitXY"
        android:layout_marginTop="54dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/btnPause"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/ic_resume"
        android:elevation="3dp"
        android:padding="0dp"
        android:layout_marginTop="54dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <FrameLayout
        android:id="@+id/layoutPlayerDead"
        android:layout_width="240dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_player_dead"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnBack">
       <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
           android:id="@+id/tvPlayerDeadName"
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:textSize="16sp"
           android:text="A has dead"
           android:textColor="#FF0C10"
           android:fontFamily="@font/tradewinds_regular"
           android:shadowColor="#80000000"
           app:outerStrokeWidth="3dp"
           app:outerStrokeColor="@color/white"
           android:gravity="center"
           android:drawablePadding="7dp"
           android:drawableEnd="@drawable/ic_skullcap"
           android:layout_gravity="center"/>
        
    </FrameLayout>

    <View
        android:id="@+id/viewOverlayDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone" />

    <com.wanted.poster.hihi.activity_app.game.CountdownRadarView
        android:id="@+id/countdownRadarView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
        android:id="@+id/tvOverLay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fontFamily="@font/tradewinds_regular"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:shadowDy="6"
        android:shadowRadius="0.1"
        android:text="PAUSED"
        android:textColor="@color/white"
        android:textSize="42sp"
        android:visibility="gone"
        app:outerStrokeColor="@color/black"
        app:outerStrokeWidth="2dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
