<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/img_bg_app">



    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        >
        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar"/>
    </FrameLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        android:orientation="vertical">


        <!-- Subtitle -->
        <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_a_number_to_survive"
            android:textColor="#DDDDDD"
            android:textSize="16sp"
            android:fontFamily="@font/tradewinds_regular"
            android:gravity="center"
            android:layout_marginStart="17dp"
            app:outerStrokeColor="@color/black"
            app:outerStrokeWidth="2dp"
            android:shadowDy="6"
            android:shadowRadius="0.1"
            android:layout_gravity="start"
            android:shadowColor="#80000000"
            android:paddingBottom="8dp" />

        <!-- Map view -->
        <com.wanted.poster.hihi.activity_app.game.MapNumberView
            android:id="@+id/mapNumberView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="40dp"
            android:layout_weight="1" />

        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/img_home_0"
            android:layout_marginBottom="50dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:id="@+id/btnStart"
            android:layout_marginTop="30dp"
            >

            <com.wanted.poster.hihi.core.custom.text.DoubleStrokeTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:outerStrokeColor="@color/black"
                app:outerStrokeWidth="2dp"
                android:shadowDy="6"
                android:shadowRadius="0.01"
                android:shadowColor="#80000000"
                android:text="@string/start"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:gravity="center"
                android:fontFamily="@font/tradewinds_regular"
                android:textSize="24sp"
                />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
